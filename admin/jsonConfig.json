{
  "i18n": true,
  "type": "tabs",
  "items": {
    "authentication": {
      "type": "panel",
      "label": "Authentication",
      "icon": "auth",
      "items": {
        "username": {
          "type": "text",
          "label": "username_label",
          "placeholder": "your-username@example.com",
          "sm": 12,
          "newLine": true,
          "validator": "!!data.username",
          "validatorErrorText": "Username is required"
        },
        "password": {
          "type": "password",
          "label": "password_label",
          "sm": 12,
          "newLine": true,
          "validator": "!!data.password",
          "validatorErrorText": "Password is required"
        },
        "_info": {
          "type": "staticText",
          "text": "Enter your ECOVACS account credentials to connect to your devices.",
          "newLine": true,
          "sm": 12
        }
      }
    },
    "debugging": {
      "type": "panel",
      "label": "Debug Options",
      "icon": "info",
      "items": {
        "_debugInfo": {
          "type": "staticText",
          "text": "Enable debug options to see detailed logs in the adapter logs. Useful for troubleshooting connection issues.",
          "newLine": true,
          "sm": 12
        },
        "debugAuth": {
          "type": "checkbox",
          "label": "debug_auth_label",
          "sm": 12,
          "newLine": true,
          "help": "Log authentication requests and responses"
        },
        "debugTopics": {
          "type": "checkbox",
          "label": "debug_topics_label",
          "sm": 12,
          "newLine": true,
          "help": "Log MQTT topics and device commands"
        },
        "debugRawTraffic": {
          "type": "checkbox",
          "label": "debug_raw_traffic_label",
          "sm": 12,
          "newLine": true,
          "help": "Log all raw MQTT messages (verbose)"
        },
        "rawMessages": {
          "type": "checkbox",
          "label": "RawMessages",
          "sm": 12,
          "newLine": true,
          "help": "Enable Goat rawMessage callback logging (all raw callback messages)"
        },
        "rawStates": {
          "type": "checkbox",
          "label": "Raw JSON States",
          "sm": 12,
          "newLine": true,
          "help": "Create and update raw JSON states (disable to reduce state traffic)"
        }
      }
    }
  }
}